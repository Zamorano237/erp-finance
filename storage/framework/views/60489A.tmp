<?php ($title = $budgetLine->exists ? 'Modifier une ligne budgétaire' : 'Créer une ligne budgétaire'); ?>
<?php ($subtitle = 'Socle budgétaire modulaire pour analyses et écarts.'); ?>

<?php $__env->startSection('content'); ?>
    <form method="POST" action="<?php echo e($budgetLine->exists ? route('budgets.update', $budgetLine) : route('budgets.store')); ?>" class="card-premium p-6">
        <?php echo csrf_field(); ?>
        <?php if($budgetLine->exists): ?> <?php echo method_field('PUT'); ?> <?php endif; ?>

        <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
            <input type="number" name="year" value="<?php echo e(old('year', $budgetLine->year)); ?>" class="rounded-2xl border border-white/10 bg-slate-950/40 px-4 py-3" placeholder="Année">
            <input type="number" name="month" value="<?php echo e(old('month', $budgetLine->month)); ?>" class="rounded-2xl border border-white/10 bg-slate-950/40 px-4 py-3" placeholder="Mois">
            <select name="third_party_type" class="rounded-2xl border border-white/10 bg-slate-950/40 px-4 py-3">
                <?php $__currentLoopData = $tiersTypes; $__env->addLoop($__currentLoopData); foreach($__currentLoopData as $type): $__env->incrementLoopIndices(); $loop = $__env->getLastLoop(); ?>
                    <option value="<?php echo e($type); ?>" <?php if(old('third_party_type', $budgetLine->third_party_type) === $type): echo 'selected'; endif; ?>><?php echo e($type); ?></option>
                <?php endforeach; $__env->popLoop(); $loop = $__env->getLastLoop(); ?>
            </select>
            <select name="budget_category" class="rounded-2xl border border-white/10 bg-slate-950/40 px-4 py-3">
                <?php $__currentLoopData = $budgetCategories; $__env->addLoop($__currentLoopData); foreach($__currentLoopData as $category): $__env->incrementLoopIndices(); $loop = $__env->getLastLoop(); ?>
                    <option value="<?php echo e($category); ?>" <?php if(old('budget_category', $budgetLine->budget_category) === $category): echo 'selected'; endif; ?>><?php echo e($category); ?></option>
                <?php endforeach; $__env->popLoop(); $loop = $__env->getLastLoop(); ?>
            </select>
            <input name="supplier_name" value="<?php echo e(old('supplier_name', $budgetLine->supplier_name)); ?>" class="rounded-2xl border border-white/10 bg-slate-950/40 px-4 py-3" placeholder="Tiers ou fournisseur">
            <input type="number" step="0.01" name="budget_amount" value="<?php echo e(old('budget_amount', $budgetLine->budget_amount)); ?>" class="rounded-2xl border border-white/10 bg-slate-950/40 px-4 py-3" placeholder="Montant">
            <input name="budget_version" value="<?php echo e(old('budget_version', $budgetLine->budget_version ?? 'V1')); ?>" class="rounded-2xl border border-white/10 bg-slate-950/40 px-4 py-3" placeholder="Version budget">
        </div>

        <textarea name="comments" rows="4" class="mt-4 w-full rounded-2xl border border-white/10 bg-slate-950/40 px-4 py-3" placeholder="Commentaires"><?php echo e(old('comments', $budgetLine->comments)); ?></textarea>

        <div class="mt-6 flex justify-end gap-3">
            <a href="<?php echo e(route('budgets.index')); ?>" class="rounded-2xl border border-white/10 px-5 py-3">Annuler</a>
            <button class="rounded-2xl bg-sky-500 px-5 py-3 font-semibold text-white">Enregistrer</button>
        </div>
    </form>
<?php $__env->stopSection(); ?>

